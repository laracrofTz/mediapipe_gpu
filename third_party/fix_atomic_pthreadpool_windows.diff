+
+static inline size_t pthreadpool_load_relaxed_size_t(
+  const pthreadpool_atomic_size_t* address) {
+    return (size_t)*address;
+}
+
+static inline void* pthreadpool_load_relaxed_void_p(
+  const pthreadpool_atomic_void_p* address) {
+    return (void*)*address;
+}
+
+/* load acquired */
+static inline uint32_t pthreadpool_load_acquire_uint32_t(
+   pthreadpool_atomic_uint32_t* address) {
+    return (uint32_t)InterlockedCompareExchange((LONG volatile*)address, 0, 0);
+}
+
+static inline size_t pthreadpool_load_acquire_size_t(
+    pthreadpool_atomic_size_t* address) {
+#ifdef _WIN64
+  return (size_t)InterlockedCompareExchange64((LONGLONG volatile*)address, 0, 0);
+#else
+  return (size_t)InterlockedCompareExchange((LONG volatile*)address, 0, 0);
 #endif
+}
 
