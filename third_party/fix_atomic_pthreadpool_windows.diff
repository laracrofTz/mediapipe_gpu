+         !defined(__thumb__))
+    __asm__ __volatile__("yield");
+#elif defined(__i386__) || defined(__i686__) || defined(__x86_64__) || \
+    defined(_M_IX86) || defined(_M_X64)
+    _mm_pause();
+#else
+    pthreadpool_fence_acquire();
+#endif
+  } else {
+#ifdef _WIN32
+    Sleep(0);
+#else
+    sched_yield();
+#endif
+  }
+}
