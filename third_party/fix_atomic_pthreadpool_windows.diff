+
+static inline bool pthreadpool_try_decrement_relaxed_size_t(
+    pthreadpool_atomic_size_t* value) {
+#if defined(_WIN64)
+  size_t old = (size_t)InterlockedCompareExchange64(
+      (LONGLONG volatile*)value, 0, 0);  // atomic read
+  while (old != 0) {
+    size_t prev = (size_t)InterlockedCompareExchange64(
+        (LONGLONG volatile*)value, (LONGLONG)(old - 1), (LONGLONG)old);
+    if (prev == old) {
+      return true;  // success
+    }
+    old = prev;  // retry with updated value
+  }
+#else
+  size_t old = (size_t)InterlockedCompareExchange(
+      (LONG volatile*)value, 0, 0);  // atomic read
+  while (old != 0) {
+    size_t prev = (size_t)InterlockedCompareExchange(
+        (LONG volatile*)value, (LONG)(old - 1), (LONG)old);
+    if (prev == old) {
+      return true;  // success
+    }
+    old = prev;  // retry with updated value
+  }
+#endif
+  return false;
+}
